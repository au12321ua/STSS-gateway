# ═══════════════════════════════════════════════════════════════════
# STSS Gateway — 环境变量（复制为 .env 后修改）
#
# 复制：cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── 上游服务地址 ──────────────────────────────────────────────────
AUTH_SERVICE_URL=auth_service:8001
INFO_SERVICE_URL=info_service:8002

# ── 网关监听端口 ──────────────────────────────────────────────────
GATEWAY_PORT=8000

# ── CORS 允许的前端域名（逗号分隔，禁止使用 *）───────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 登录接口限流（Nginx rate 语法：10r/m = 每分钟10次）───────────
RATE_LIMIT_LOGIN=10r/m

# ── Gateway 服务凭据（调用 Auth Service /internal/verify 时使用）─
# 必须与 Auth Service 侧 SERVICE_CLIENT_GATEWAY_* 一致
GATEWAY_CLIENT_ID=gateway
GATEWAY_CLIENT_SECRET=change-me-gateway-secret

# ── 上游服务镜像（P2-A 组提供，按需覆盖）─────────────────────────
# AUTH_SERVICE_IMAGE=stss-auth:latest
# INFO_SERVICE_IMAGE=stss-info:latest

# ── 前端路径（dev profile 使用）───────────────────────────────────
# FRONTEND_PATH=./frontend
